{
  "name": "idk-launcher",
  "version": "1.2.0-preview.26w20a",
  "author": "Jeflacc <109415855+Jeflacc@users.noreply.github.com>",
  "private": true,
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev:electron": "concurrently \"npm run dev\" \"npm run electron\"",
    "dist": "npm run build && electron-builder --win",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder --win --mac --linux"
  },
  "build": {
    "appId": "com.vathir.idklauncher",
    "productName": "IDK Launcher",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "icon": "logo.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "icon": "logo.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "icon": "logo.png",
      "maintainer": "Jeflacc <109415855+Jeflacc@users.noreply.github.com>",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "Jeflacc",
      "repo": "idk-launcher"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "preload.cjs",
      "splash.html",
      "logo.png",
      "public/**/*"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "cross-env": "^10.1.0",
    "minecraft-launcher-core": "^3.18.2"
  }
}
